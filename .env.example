# MOR Trading Stack — Environment Variables
# Copy to .env and fill in your values

# === PETE (Perplexity MCP) ===
PETE_PERPLEXITY_API_KEY=pplx-xxxxxxxxxxxxxxxxxxxx
PETE_BRIDGE_TOKEN=your_pete_bridge_token_here

# === GitHub MCP ===
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# === Notion MCP ===
NOTION_API_TOKEN=secret_xxxxxxxxxxxxxxxxxxxx
NOTION_INTEGRATION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxx

# === TradingView MCP (Jackson) ===
TV_MCP_HOST=localhost
TV_MCP_PORT=8765
JACKSON_BRIDGE_URL=https://bridge.morairelectric.com/pete/mcp/invoke

# === mcp-optionsflow ===
OPTIONSFLOW_API_KEY=your_optionsflow_key_here
OPTIONSFLOW_ENDPOINT=https://api.optionsflow.io/mcp

# === OpenClaw Bridge ===
OPENCLAW_HOST=localhost
OPENCLAW_PORT=9000
OPENCLAW_SECRET=your_openclaw_secret_here

# === GCP (when deployed) ===
GCP_PROJECT_ID=mor-trading-prod
GCP_REGION=us-central1
